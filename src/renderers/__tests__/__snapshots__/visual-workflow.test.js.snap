      </linearGradient>
      <filter id="lineGlow-chart-28-100" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="3" result="blur"/>
        <feMerge>
          <feMergeNode in="blur"/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>
    </defs>
  
    <line x1="12" y1="12" x2="388" y2="12" stroke="#2a2a40" stroke-width="1" opacity="0.3" stroke-dasharray="4 4"/>
