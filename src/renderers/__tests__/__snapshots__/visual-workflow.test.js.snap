        <feMerge>
          <feMergeNode in="blur"/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>
    </defs>
  
    <line x1="12" y1="12" x2="388" y2="12" stroke="#1e1e2e" stroke-width="1" opacity="0.3" stroke-dasharray="4 4"/>
