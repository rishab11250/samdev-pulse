      <rect x="50" y="70" width="3" height="30" rx="1.5" fill="#3ddc84" opacity="0.9"/>
    
  </g>

  <g transform="translate(28, 100)">
    
    <defs>
      <linearGradient id="lineGradient-chart-28-100" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#3ddc84"/>
