# =============================================================================
# samdev-pulse — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- GitHub API --------------------------------------------------------------
# GitHub Personal Access Token (required for higher API rate limits & streak stats)
# Create one at: https://github.com/settings/tokens
# No special scopes needed — public access only
GITHUB_TOKEN=ghp_your_token_here

# --- Server ------------------------------------------------------------------
# Port the server listens on (optional — defaults to 3000)
PORT=3000

# Node environment (optional — defaults to development)
# Accepted values: development, production
NODE_ENV=development

# --- Cache -------------------------------------------------------------------
# In-memory cache maximum entries (optional — defaults to 1000)
# Production TTL: 30 minutes | Development TTL: 5 minutes
CACHE_MAX_SIZE=1000

# --- Analytics (MongoDB) -----------------------------------------------------
# MongoDB connection URI (optional — analytics logging)
# If not set, analytics are silently disabled
MONGODB_URI=mongodb://localhost:27017/samdev-pulse

# MongoDB database name (optional — defaults to the database name in MONGODB_URI)
# MONGODB_DB=samdev-pulse

# Set to "true" to disable analytics logging even when MONGODB_URI is set (optional)
# ANALYTICS_DISABLED=true

# --- Admin -------------------------------------------------------------------
# API key for protected admin endpoints (optional — /api/cache/stats requires this)
# If not set, cache stats are publicly accessible
# ADMIN_API_KEY=your_admin_key_here